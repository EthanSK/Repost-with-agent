{
  "schemaVersion": 4,
  "notification": {
    "delivery": {
      "harness": "openclaw",
      "channel": "telegram",
      "accountId": "<current-harness-account-id>",
      "target": "telegram:<chat-or-user-id>",
      "threadId": null
    },
    "payloadStyle": "short-human",
    "noRawToolOutput": true
  },
  "customRules": [],
  "pairs": [
    {
      "id": "linkedin-to-x",
      "name": "LinkedIn to X",
      "enabled": false,
      "mode": "preview-only",
      "runMode": "listen-for-future",
      "source": {
        "platform": "linkedin",
        "url": "https://www.linkedin.com/in/<your-handle>/recent-activity/all/",
        "profileUrl": "https://www.linkedin.com/in/<your-handle>"
      },
      "destination": {
        "platform": "x",
        "accountHint": "@<your-handle>",
        "accountDisplayName": "<visible account/profile name>",
        "targetType": "profile",
        "profileUrl": "https://x.com/<your-handle>"
      },
      "schedule": {
        "kind": "cron",
        "tz": "Europe/London",
        "expression": "0 10 * * *",
        "everyHours": 24
      },
      "policy": {
        "maxItemsPerRun": 1,
        "minDelayBetweenPostsMinutes": 60,
        "blockOnUncertainDuplicate": true,
        "overlengthStrategy": "compact",
        "globalDedupeEnabled": true,
        "semanticDedupeEnabled": true,
        "semanticDedupeWindowSize": 30
      },
      "createdAt": "2026-05-01T12:00:00Z",
      "updatedAt": "2026-05-01T12:00:00Z"
    }
  ]
}
