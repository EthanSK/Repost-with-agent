{
  "version": 1,
  "pairs": [
    {
      "id": "linkedin-to-x-example",
      "name": "LinkedIn to X example",
      "enabled": false,
      "mode": "preview-only",
      "runMode": "listen-for-future",
      "source": {
        "platform": "linkedin",
        "url": "https://www.linkedin.com/in/example/recent-activity/all/",
        "authRef": "browser-mcp:linkedin"
      },
      "destination": {
        "platform": "x",
        "accountHint": "@example",
        "authRef": "browser-mcp:x"
      },
      "schedule": {
        "kind": "manual",
        "tz": "Europe/London"
      },
      "policy": {
        "requirePreviewBeforeFirstLiveRun": true,
        "maxItemsPerRun": 1,
        "minDelayBetweenPostsMinutes": 60,
        "preferOfficialApi": false,
        "blockOnUncertainDuplicate": true
      },
      "dedupe": {
        "strategy": "source-id-url-content-hash"
      },
      "schemaVersion": 3
    },
    {
      "id": "linkedin-to-bluesky-example",
      "name": "LinkedIn to Bluesky example",
      "enabled": false,
      "mode": "preview-only",
      "runMode": "backfill",
      "source": {
        "platform": "linkedin",
        "url": "https://www.linkedin.com/in/example/recent-activity/all/"
      },
      "destination": {
        "platform": "bluesky",
        "accountHint": "example.bsky.social"
      },
      "schedule": {
        "kind": "manual",
        "tz": "Europe/London"
      },
      "policy": {
        "requirePreviewBeforeFirstLiveRun": true,
        "maxItemsPerRun": 1,
        "minDelayBetweenPostsMinutes": 60,
        "preferOfficialApi": false,
        "blockOnUncertainDuplicate": true
      },
      "dedupe": {
        "strategy": "source-id-url-content-hash"
      },
      "schemaVersion": 3
    }
  ]
}
