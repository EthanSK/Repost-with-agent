{
  "name": "repost-with-agent",
  "version": "2.2.0",
  "description": "Agent-operated social/source-to-destination reposting with saved pairs and queue workspaces",
  "main": "dist/index.js",
  "bin": {
    "repost-with-agent": "./dist/index.js",
    "linkedin-to-x": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node tests/dedupe-regression.js",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "sync": "tsx src/index.ts sync",
    "list": "tsx src/index.ts list",
    "pair:list": "tsx src/index.ts pair list",
    "workspace:init": "python3 scripts/init_repost_with_agent_workspace.py"
  },
  "keywords": ["repost", "social", "linkedin", "x", "cross-post", "playwright"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "playwright": "^1.49.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
